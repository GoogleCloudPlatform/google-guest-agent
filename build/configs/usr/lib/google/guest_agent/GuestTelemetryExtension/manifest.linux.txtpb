# proto-file: internal/acp/proto/agent_controlplane.proto
# proto-message: agent_controlplane.ConfigurePluginStates.ConfigurePlugin

plugin: {
  name: "GuestTelemetryExtension"
  entry_point: "/usr/lib/google/guest_agent/GuestTelemetryExtension/guest_telemetry"
  revision_id: "1.1"
}
manifest: {
  start_attempt_count: 5
  start_timeout: {
    seconds: 30
  }
  stop_timeout: {
    seconds: 30
  }
  plugin_type: DAEMON
  execution_model: {
    boot_critical: false
  }
}
