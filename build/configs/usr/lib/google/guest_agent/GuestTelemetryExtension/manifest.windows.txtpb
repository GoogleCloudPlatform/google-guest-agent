# proto-file: internal/acp/proto/agent_controlplane.proto
# proto-message: agent_controlplane.ConfigurePluginStates.ConfigurePlugin

# LINT.IfChange
plugin: {
  name: "GuestTelemetryExtension"
  entry_point: "C:\\Program Files\\Compute Engine\\agent\\GuestTelemetryExtension\\GuestTelemetry.exe"
  revision_id: "1.0"
}
manifest: {
  start_attempt_count: 5
  start_timeout: {
    seconds: 30
  }
  stop_timeout: {
    seconds: 30
  }
  plugin_type: DAEMON
  execution_model: {
    boot_critical: false
  }
}
# The binpb files can be generated by running third_party/guest_agent/dev/build/regen-binpb.sh
# LINT.ThenChange(manifest.windows.binpb)
