# proto-file: isvdiscovery/proto/definition.proto
# proto-message: DiscoveryRules

rules: {
  discovered_workload_name: "cassandra"
  condition: {
    string_match: {
      vm_field: VM_PROCESS_NAME
      regex_match: "CassandraDaemon"
    }
  }
  version_rules: [
    {
      command: NODETOOL
      command_args: ["version"]
      regex_match: "^ReleaseVersion: [0-9]+(\\.[0-9]+)+(-[a-zA-Z0-9]+)?"
    },
    {
      command: CASSANDRA_NODETOOL
      command_args: ["version"]
      regex_match: "^ReleaseVersion: [0-9]+(\\.[0-9]+)+(-[a-zA-Z0-9]+)?"
    },
    {
      command: SBIN_NODETOOL
      command_args: ["version"]
      regex_match: "^ReleaseVersion: [0-9]+(\\.[0-9]+)+(-[a-zA-Z0-9]+)?"
    }
  ]
}
